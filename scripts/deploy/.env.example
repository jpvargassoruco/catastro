# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno para el stack Catastro → Odoo
# Copia este archivo a .env en la raíz del proyecto y ajusta los valores.
# NUNCA subas el .env real a git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Directorio raíz del proyecto ─────────────────────────────────────────────
# En WSL: ruta dentro del sistema de archivos WSL (ej. /opt/catastro)
# En Linux: ruta del clon del repositorio
CATASTRO_DIR=/home/kali/catastro

# ── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_DB=catastro
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo_secret

# ── Odoo ─────────────────────────────────────────────────────────────────────
# Contraseña maestra de Odoo (para crear/eliminar bases de datos)
ODOO_MASTER_PASSWORD=catastro_admin_2026

# Nombre de la base de datos que Odoo usará por defecto
ODOO_DB=catastro

# ── Imagen Docker ─────────────────────────────────────────────────────────────
# Imagen del registro de contenedores (GHCR, Docker Hub, etc.)
ODOO_IMAGE=ghcr.io/jpvargassoruco/catastro:latest

# ── Entorno (dev | prod) ──────────────────────────────────────────────────────
CATASTRO_ENV=dev

# ── Notificaciones de deploy (opcional) ──────────────────────────────────────
# URL de webhook de Slack/Teams para notificar el deploy
# Dejar vacío para deshabilitar
DEPLOY_WEBHOOK_URL=

# ── Backup de producción ──────────────────────────────────────────────────────
# Directorio donde se guardan los backups automáticos antes de cada deploy
BACKUP_DIR=/var/backups/catastro
# Retención: número de backups a conservar (los más antiguos se borran)
BACKUP_RETENTION=7
