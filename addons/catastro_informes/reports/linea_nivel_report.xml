<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_linea_nivel" model="ir.actions.report">
        <field name="name">Línea de Nivel y Cota (PDF)</field>
        <field name="model">catastro.informe</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">catastro_informes.report_linea_nivel_doc</field>
        <field name="report_file">catastro_informes.report_linea_nivel_doc</field>
        <field name="binding_model_id" ref="model_catastro_informe"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_linea_nivel_doc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-if="doc.tipo_informe == 'linea_nivel'">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div class="text-center bg-dark text-white p-3 mb-4 rounded">
                                <h3><strong>CERTIFICACIÓN DE LÍNEA Y COTA DE NIVEL</strong></h3>
                            </div>
                            <div class="row border p-4">
                                <div class="col-6">
                                    <p><strong>Código Catastral Corto:</strong> <span t-field="doc.predio_id.codigo_catastral"/></p>
                                </div>
                                <div class="col-6 text-end">
                                    <p><strong>Propietario / Representante:</strong> <span t-field="doc.predio_id.propietario_id.name"/></p>
                                </div>
                                <div class="col-12 mt-4">
                                    <hr/>
                                    <h5 class="mb-3 text-primary"><strong>ESPECIFICACIONES TOPOGRÁFICAS LÍMITE</strong></h5>
                                    <p class="text-justify lh-lg" style="white-space: pre-wrap;"><span t-field="doc.conclusiones"/></p>
                                </div>
                            </div>
                            <div class="row mt-5 text-end">
                                <div class="col-12">
                                     <p>Emitido por Obras Públicas / Topografía el <strong><span t-field="doc.fecha_emision"/></strong></p>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
