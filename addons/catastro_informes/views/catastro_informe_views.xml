<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_catastro_informe_tree" model="ir.ui.view">
        <field name="name">catastro.informe.tree</field>
        <field name="model">catastro.informe</field>
        <field name="arch" type="xml">
            <tree string="Informes Técnicos Múltiples">
                <field name="name"/>
                <field name="predio_id"/>
                <field name="tipo_informe"/>
                <field name="fecha_emision"/>
                <field name="tecnico_id"/>
                <field name="estado" widget="badge" decoration-warning="estado == 'borrador'" decoration-muted="estado == 'finalizado'"/>
            </tree>
        </field>
    </record>

    <record id="action_catastro_informes" model="ir.actions.act_window">
        <field name="name">Gestión de Informes</field>
        <field name="res_model">catastro.informe</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Levantar un nuevo relevamiento físico / técnico
            </p>
        </field>
    </record>

    <menuitem id="menu_catastro_informes" 
              name="Informes de Campo" 
              action="action_catastro_informes"
              parent="catastro_predio.menu_catastro_root"
              sequence="60"/>
</odoo>
