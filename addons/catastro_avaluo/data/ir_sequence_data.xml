<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Secuencia para código de avalúo -->
    <record id="seq_catastro_avaluo" model="ir.sequence">
        <field name="name">Avalúo Catastral</field>
        <field name="code">catastro.avaluo</field>
        <field name="prefix">AV-%(year)s-</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
