<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Vista heredada del PREDIO para agregar pestaña de avalúos ══ -->
    <record id="catastro_predio_view_form_avaluo" model="ir.ui.view">
        <field name="name">catastro.predio.form.avaluo</field>
        <field name="model">catastro.predio</field>
        <field name="inherit_id" ref="catastro_predio.view_catastro_predio_form"/>
        <field name="arch" type="xml">

            <!-- Stat button con contador de avalúos — antes del bloque oe_title -->
            <xpath expr="//sheet/div[hasclass('oe_title')]" position="before">
                <div class="oe_button_box" name="button_box">
                    <button class="oe_stat_button" icon="fa-calculator"
                            name="action_ver_avaluos" type="object">
                        <field name="avaluo_count" widget="statinfo" string="Avalúos"/>
                    </button>
                </div>
            </xpath>

            <!-- Grupo de avalúo vigente — después del group principal de datos -->
            <xpath expr="//sheet/group" position="after">
                <group name="group_avaluo_vigente"
                       invisible="not avaluo_vigente_id">
                    <group string="Avalúo Catastral Vigente">
                        <field name="avaluo_vigente_id" readonly="1"/>
                        <field name="gestion_avaluo_vigente" readonly="1"/>
                        <field name="valor_catastral_vigente" readonly="1"/>
                    </group>
                </group>
            </xpath>

            <!-- Pestaña de avalúos históricos al final del predio -->
            <xpath expr="//notebook" position="inside">
                <page string="Avalúos" name="page_avaluos">
                    <field name="avaluo_ids" readonly="1">
                        <tree decoration-success="state == 'vigente'"
                              decoration-muted="state == 'historico'">
                            <field name="name"/>
                            <field name="gestion"/>
                            <field name="tabla_valor_id"/>
                            <field name="valor_catastral"/>
                            <field name="state" widget="badge"/>
                            <field name="fecha_calculo"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
