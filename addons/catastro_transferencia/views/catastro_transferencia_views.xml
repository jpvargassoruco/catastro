<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_catastro_transferencia_tree" model="ir.ui.view">
        <field name="name">catastro.transferencia.tree</field>
        <field name="model">catastro.transferencia</field>
        <field name="arch" type="xml">
            <tree string="Transferencias">
                <field name="name"/>
                <field name="predio_id"/>
                <field name="vendedor_id"/>
                <field name="comprador_id"/>
                <field name="fecha_solicitud"/>
                <field name="estado" widget="badge" decoration-info="estado == 'borrador'" decoration-success="estado == 'aprobado'"/>
            </tree>
        </field>
    </record>

    <record id="action_catastro_transferencias" model="ir.actions.act_window">
        <field name="name">Transferencias de Dominio</field>
        <field name="res_model">catastro.transferencia</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Iniciar un trámite de transferencia de dominio
            </p>
        </field>
    </record>

    <menuitem id="menu_catastro_transferencias" 
              name="Transferencias" 
              action="action_catastro_transferencias"
              parent="catastro_predio.menu_catastro_root"
              sequence="30"/>
</odoo>
